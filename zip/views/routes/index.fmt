{% function block.content() %}
	<h1>DavidPineiro.xyz</h1>

	<p>This is David Pineiro's website and portfolio.</p>
	
	<h2>About Me</h2>
	<p>
		I like programming random things and learning about science and programming.
	</p>

	<h2>My Links</h2>
	<form id="turnstileForm" action="" method="">
		<div class="cf-turnstile" data-sitekey="{%& vars.turnstile_key %}" data-callback="turnstileEnable" data-error-callback="turnstileDisable" data-expired-callback="turnstileDisable" data-timeout-callback="turnstileDisable"></div>
		<button type="submit" id="emailButton" disabled="true"><h3>Click To Populate</h3></button>
	</form>
	<ul>
		<li>GitHub: {%= raw.link("https://github.com/thatshawt", "https://github.com/thatshawt", "unsafe") %}</li>
		<li>Resume: {%= raw.link("https://foobar", "", "safe", "id='resume' style='display:none;'") %}</li>
		<li>LinkedIn: {%= raw.link("https://foobar", "", "safe", "id='linkedin' style='display:none;'") %}</li>
		<li>
			My Email: <pre class="inline" id="email"></pre>
		</li>

		<script>
			function turnstileEnable(){
				document.getElementById('emailButton').disabled = false;
			}

			function turnstileDisable(){
				document.getElementById('emailButton').disabled = true;
			}

			turnstileDisable();

			document.getElementById('turnstileForm').addEventListener('submit', function(event) {
				event.preventDefault();
				const formData = new FormData(this);

				fetch('/getInfo', {
					method: 'POST',
					body: formData
				})
				.then(response => response.json())
				.then(data => {
					console.log('Success:', data)
					if(data.success == "true"){
						document.getElementById("email").textContent = data.email;

						document.getElementById("resume").href = data.resume;
						document.getElementById("resume").textContent = "resume.pdf";
						document.getElementById("resume").style = "";

						document.getElementById("linkedin").href = data.linkedin;
						document.getElementById("linkedin").textContent = data.linkedin;
						document.getElementById("linkedin").style = "";

						turnstileDisable();
					}
				})
				.catch(error => console.error('Error:', error));
			});
		</script>
		
		
	</ul>

	<!-- <h2>Cat</h2> -->
	<div class="inner-box">
		ᓚᘏᗢ &lt;&lt;&lt; it's a cat
		<video src="/static/cats3.webm" autoplay="" muted="" loop="" playsinline=""></video>
	</div>

	<!-- <hr> -->

	<h2>My 88x31 Badges</h2>
	<ul>
		<li><div class="inner-box">
			<h3>Animated (15.0 KiB):</h3>
			{% block.makeBadge("https://davidpineiro.xyz/", "/static/david-badge-88x31.gif") %}
			<code class="badge-code">&lt;a target="_blank" rel="noopener noreferrer" href=&quot;https://davidpineiro.xyz/&quot;&gt;&lt;img src=&quot;https://davidpineiro.xyz/static/david-badge-88x31.gif&quot; alt=&quot;davidpineiro.xyz badge&quot;&gt;&lt;/a&gt;</code>
		</div></li>

		<li><div class="inner-box">
			<h3>Static (3.2 KiB):</h3>
			{% block.makeBadge("https://davidpineiro.xyz/", "/static/david-badge-88x31.png") %}
			<code class="badge-code">&lt;a target="_blank" rel="noopener noreferrer" href=&quot;https://davidpineiro.xyz/&quot;&gt;&lt;img src=&quot;https://davidpineiro.xyz/static/david-badge-88x31.png&quot; alt=&quot;davidpineiro.xyz badge&quot;&gt;&lt;/a&gt;</code>
		</div></li>
	</ul>
	<h2>Cool Stuff</h2>
	<div>
		{% block.makeBadge("https://justine.lol/cosmopolitan/", "/static/cosmopolitan-88x31.png") %}
		{% block.makeBadge("https://molecule31.neocities.org/", "/static/molecule31.gif") %}
		{% block.makeBadge("https://scp-wiki.wikidot.com/", "/static/scp-88x31.gif") %}
		{% block.makeBadge("https://smokepowered.com/", "https://smokepowered.com/smoke.gif") %}
		{% block.makeBadge("https://yummypillow.art/", "https://yummypillow.art/buttons/pillow.png") %}
		{% block.makeBadge("https://bigrat.monster/", "/static/bigrat-88x31.png") %}
		{% block.makeBadge("https://corru.observer/", "/static/corru.gif") %}
		{% block.makeBadge("https://melankorin.net/", "/static/melankorin.gif") %}
		{% block.makeBadge("https://lunabee.space/", "https://lunabee.space/8831.gif") %}
		{% block.makeBadge("https://notnite.com/", "https://notnite.com/buttons/notnite.png") %}
		{% block.makeBadge("https://dimden.dev/", "/static/dimden.gif") %}
		{% block.makeBadge("https://fleepy.tv/", "https://fleepy.tv/img/fleepy.png") %}
		{% block.makeBadge("https://msx.horse/", "/static/msx_horse.gif") %}
		{% block.makeBadge("https://zvava.org/", "https://zvava.org/images/buttons/zvava.org.png") %}
		{% block.makeBadge("https://libdb.so/", "/static/libdbso.gif") %}
		{% block.makeBadge("https://goth.zip/", "https://goth.zip/_astro/button.bccee393_ZrDNs4.webp") %}
		{% block.makeBadge("https://zptr.cc/", "https://zptr.cc/88x31/webring/zeroptr.png") %}
		{% block.makeBadge("https://hl2.sh/", "https://hl2.sh/badges/cecilia.png") %}
	</div>
{% end %}
{% render("common", {title="Home"}) %}