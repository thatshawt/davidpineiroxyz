{% function block.content() %}
	<h1>DavidPineiro.xyz</h1>

	<p>This is David Pineiro's website and portfolio.</p>
	
	<h2>About Me</h2>
	<p>
		I like programming random things and learning about science and programming.
	</p>

	<h2>Socials</h2>
	<form id="turnstileForm" action="" method="">
		<ul>
			<li>GitHub: {%= raw.link("https://github.com/thatshawt", "https://github.com/thatshawt", "unsafe") %}</li>
			<li>Resume: {%= raw.link("https://foobar", "", "safe", "id='resume' style='display:none;'") %}</li>
			<li>LinkedIn: {%= raw.link("https://foobar", "", "safe", "id='linkedin' style='display:none;'") %}</li>
			<li>
				My Email: <span class="inline" id="email"></span>
			</li>
		</ul>
		<button type="submit" id="emailButton" disabled="true"><span>Show Socials</span></button>
		<div id="turnstileDiv"></div>
	</form>

	<!-- turnstile javscript -->
	<script>
		function turnstileEnable(){
			document.getElementById('emailButton').disabled = false;
		}

		function turnstileDisable(){
			document.getElementById('emailButton').disabled = true;
		}

		turnstileDisable();

		document.getElementById('turnstileForm').addEventListener('submit', function(event) {
			event.preventDefault();
			const formData = new FormData(this);

			fetch('/getInfo', {
				method: 'POST',
				body: formData
			})
			.then(response => response.json())
			.then(data => {
				console.log('Success:', data)
				if(data.success == "true"){
					document.getElementById("email").textContent = data.email;

					document.getElementById("resume").href = data.resume;
					document.getElementById("resume").textContent = "resume.pdf";
					document.getElementById("resume").style = "";

					document.getElementById("linkedin").href = data.linkedin;
					document.getElementById("linkedin").textContent = data.linkedin;
					document.getElementById("linkedin").style = "";

					turnstileDisable();
				}
			})
			.catch(error => console.error('Error:', error));
		});
	</script>

	{% block.turnstileScript("turnstileDiv", "turnstileEnable", "turnstileDisable", "turnstileDisable", "turnstileDisable") %}

	<h2>Links</h2>
	<ul>
		<li>{%= raw.outLink("/copyparty/", "Culture Receptacle") %}</li>
	</ul>

	<h2>Cats; <code class="inline" style="padding-right:9px;">ᓚᘏᗢ</code> "Meow"</h2>
	<div class="static-bg inner-box">
		<video id="catvideo" src="/static/media/cats3.webm" autoplay="" muted="" loop="" playsinline=""></video>
	</div>

	<script>
		tippy('#catvideo', {content: 'cat portal ᓚᘏᗢ O.o', followCursor: true,});
	</script>


	<h2>My Badges</h2>
	<table>
		<tr>
			<td>Badge</td>
			<td>HTML Code</td>
		</tr>
		<tr>
			<td><div>Static (3.2 KiB):</div>
			{% block.makeBadge("https://davidpineiro.xyz/", "/static/david-badge-88x31.png") %}</td>
			<td><code class="badge-code">{%& [[<a target="_blank" rel="noopener noreferrer" href="https://davidpineiro.xyz/"><img src="https://davidpineiro.xyz/static/david-badge-88x31.png" alt="davidp web badge"></a>]] %}</code></td>
		</tr>
		<tr>
			<td><div>Animated (15.0 KiB):</div>
			{% block.makeBadge("https://davidpineiro.xyz/", "/static/david-badge-88x31.gif") %}</td>
			<td><code class="badge-code">{%& [[<a target="_blank" rel="noopener noreferrer" href="https://davidpineiro.xyz/"><img src="https://davidpineiro.xyz/static/david-badge-88x31.gif" alt="davidp web badge"></a>]] %}</code></td>
		</tr>
		<tr>
			<td><div>Square (139.9 KiB):</div>
			{%= raw.link("https://davidpineiro.xyz/", [[<img src="/static/davidp-navlink.png" alt="">]], "unsafe") %}</td>
			<td><code class="badge-code">{%& [[<a target="_blank" rel="noopener noreferrer" href="https://davidpineiro.xyz/"><img src="https://davidpineiro.xyz/static/davidp-navlink.png" alt="davidp web badge"></a>]] %}</code></td>
		</tr>
	</table>

